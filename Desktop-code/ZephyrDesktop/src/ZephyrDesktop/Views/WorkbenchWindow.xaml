<Window x:Class="ZephyrDesktop.Views.WorkbenchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="轻燕 - 工作台" Height="700" Width="1000"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Background="Transparent">
    <Border CornerRadius="8" Background="#f3f4f6">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="16" Opacity="0.25" Color="Black"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#1e40af" CornerRadius="8,8,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="12,0">
                    <TextBlock Text="轻燕 - 工作台" FontSize="14" FontWeight="SemiBold"
                               Foreground="White" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="MinimizeButton" Content="−" FontSize="16" Width="32" Height="28"
                                Background="Transparent" Foreground="White" BorderThickness="0"
                                Click="MinimizeButton_Click"/>
                        <Button x:Name="CloseButton" Content="✕" FontSize="12" Width="32" Height="28"
                                Background="Transparent" Foreground="White" BorderThickness="0"
                                Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <wv2:WebView2 Grid.Row="1" x:Name="WorkbenchWebView"/>
        </Grid>
    </Border>
</Window>
