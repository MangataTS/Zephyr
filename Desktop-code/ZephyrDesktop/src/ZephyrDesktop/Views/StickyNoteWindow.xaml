<Window x:Class="ZephyrDesktop.Views.StickyNoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:controls="clr-namespace:ZephyrDesktop.Views.Controls"
        Title="" Height="320" Width="280"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" Topmost="False"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Border x:Name="NoteBorder" CornerRadius="12" Margin="4"
            Background="#FEF3C7" PreviewMouseLeftButtonDown="NoteBorder_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.08" Color="#000000"/>
        </Border.Effect>
        <Grid Margin="12" x:Name="RootGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" x:Name="TaskTypeBar">
                <Border x:Name="TaskTypeLabel" Background="#FEE2E2" CornerRadius="4" Padding="6,1"
                        Visibility="Collapsed" Margin="0,0,4,0">
                    <TextBlock x:Name="TaskTypeText" FontSize="10" Foreground="#DC2626" FontWeight="Medium"/>
                </Border>
                <TextBlock x:Name="RemainingTimeText" FontSize="10" Foreground="#6b7280"
                           VerticalAlignment="Center" Visibility="Collapsed"/>
                <TextBlock x:Name="SourceText"
                           FontSize="11" Foreground="#6b7280" VerticalAlignment="Center"
                           Margin="8,0,0,0"/>
            </StackPanel>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="TitleText"
                         Text="{Binding Title}" FontSize="14" FontWeight="SemiBold"
                         Foreground="#1f2937"
                         IsReadOnly="True" BorderThickness="0" Background="Transparent"
                         Padding="0" CaretBrush="#3B82F6"
                         KeyDown="TitleText_KeyDown"
                         LostFocus="TitleText_LostFocus"
                         GotFocus="TitleText_GotFocus"/>
                <Border Grid.Column="1" Background="#BFDBFE" CornerRadius="4" Padding="6,1"
                        Visibility="{Binding IsPendingSync, Converter={StaticResource BoolToVis}}"
                        VerticalAlignment="Center" Margin="4,0">
                    <TextBlock Text="⏳ 待同步" FontSize="10" Foreground="#1E40AF" FontWeight="Medium"/>
                </Border>
                <Border Grid.Column="2" Background="#FDE68A" CornerRadius="4" Padding="6,1"
                        Visibility="{Binding HasConflict, Converter={StaticResource BoolToVis}}"
                        VerticalAlignment="Center" Margin="4,0">
                    <TextBlock Text="⚠ 有更新冲突" FontSize="10" Foreground="#92400E" FontWeight="Medium"/>
                </Border>
                <Button Grid.Column="3" x:Name="PinButton"
                        Content="📌" FontSize="11" Width="24" Height="24"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand"
                        Click="PinButton_Click" ToolTip="置顶"/>
                <Button Grid.Column="4" x:Name="HideButton"
                        Content="👁" FontSize="10" Width="24" Height="24"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand"
                        Click="HideButton_Click" ToolTip="隐藏"/>
                <Button Grid.Column="5" x:Name="FoldButton"
                        Content="−" FontSize="14" Width="24" Height="24"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#9ca3af" Cursor="Hand"
                        Click="FoldButton_Click" ToolTip="折叠"/>
                <Button Grid.Column="6" x:Name="CloseButton"
                        Content="✕" FontSize="12" Width="24" Height="24"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#9ca3af" Cursor="Hand"
                        Click="CloseButton_Click"/>
            </Grid>

            <controls:TagSelectorControl Grid.Row="4" x:Name="TagSelector"
                AvailableTags="{Binding AvailableTags}"
                SelectedTagIds="{Binding SelectedTagIds}"/>

            <Grid Grid.Row="5">
                <TextBox x:Name="SubTagBox"
                         Text="{Binding SubTag}"
                         FontSize="11" Padding="4,2"
                         BorderThickness="0" Background="Transparent"
                         Foreground="#6b7280"
                         LostFocus="SubTagBox_LostFocus"
                         KeyDown="SubTagBox_KeyDown">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="0"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
                <TextBlock x:Name="SubTagPlaceholder" Text="添加二级标签"
                           FontSize="11" Foreground="#9CA3AF"
                           Padding="4,2" IsHitTestVisible="False"
                           Visibility="Collapsed"/>
            </Grid>

            <Grid Grid.Row="6" x:Name="ContentArea">
                <TextBlock x:Name="LoadingText" Text="加载中..."
                           FontSize="12" Foreground="#9ca3af"
                           VerticalAlignment="Center" HorizontalAlignment="Center"
                           Visibility="Collapsed"/>
                <Border CornerRadius="4" Background="Transparent">
                    <wv2:WebView2 x:Name="ContentWebView" MinHeight="80"/>
                </Border>
            </Grid>

            <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" x:Name="ActionBar">
                <Button x:Name="CompleteButton" Content="✓ 完成"
                        FontSize="12" Padding="8,4" Margin="0,0,4,0"
                        Background="#DCFCE7" Foreground="#166534"
                        BorderThickness="0" Cursor="Hand"
                        Click="CompleteButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="归档" Click="MenuArchive_Click"/>
        </ContextMenu>
    </Window.ContextMenu>
</Window>
