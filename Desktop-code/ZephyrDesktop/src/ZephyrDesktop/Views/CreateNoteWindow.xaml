<Window x:Class="ZephyrDesktop.Views.CreateNoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:controls="clr-namespace:ZephyrDesktop.Views.Controls"
        Title="新建任务" Height="520" Width="400"
        WindowStartupLocation="CenterScreen"
        Background="#f8fafc">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Grid>
        <Image x:Name="TecBackgroundImage" Stretch="UniformToFill" Opacity="0.12" VerticalAlignment="Bottom" Height="300"/>

        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="新建任务" FontSize="18" FontWeight="SemiBold" Foreground="#1e293b"/>

            <TextBox Grid.Row="2" x:Name="TitleBox"
                     Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="15" Padding="8,6"
                     BorderBrush="#e2e8f0" BorderThickness="1"
                     Background="White" MaxLength="200"
                     GotFocus="TitleBox_GotFocus" LostFocus="TitleBox_LostFocus"/>

            <controls:TagSelectorControl Grid.Row="4"
                                         AvailableTags="{Binding AvailableTags}"
                                         SelectedTagIds="{Binding SelectedTagIds, Mode=TwoWay}"/>

            <TextBox Grid.Row="6" x:Name="SubTagBox"
                     Text="{Binding SubTag, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="13" Padding="8,6"
                     BorderBrush="#e2e8f0" BorderThickness="1"
                     Background="White" MaxLength="100"
                     GotFocus="SubTagBox_GotFocus" LostFocus="SubTagBox_LostFocus"/>

            <controls:UserPickerControl Grid.Row="8"
                                        Users="{Binding AvailableUsers}"
                                        SelectedUsers="{Binding SelectedAssignees, Mode=TwoWay}"
                                        Visibility="{Binding CanAssign, Converter={StaticResource BoolToVis}}"/>

            <Border Grid.Row="10" CornerRadius="6" BorderBrush="#e2e8f0" BorderThickness="1" Background="White">
                <wv2:WebView2 x:Name="EditorWebView" MinHeight="200"/>
            </Border>

            <StackPanel Grid.Row="12" Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#ef4444" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <Button Content="取消" Width="80" Height="36" Margin="0,0,8,0"
                        Click="CancelButton_Click" Background="#f1f5f9" BorderThickness="0" Foreground="#64748b"/>
                <Button Content="创建" Width="80" Height="36"
                        Click="CreateButton_Click" Foreground="White" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="BtnBorder" CornerRadius="6" Background="#3B82F6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BtnBorder" Property="Background" Value="#2563eb"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>