<Window x:Class="ZephyrDesktop.Views.WorkGroupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="轻燕 - 工作组" Height="800" Width="1200"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen">
    <Border CornerRadius="8" Background="#f3f4f6">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.15" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#1e40af" CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="12,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="BackButton" Content="◀" FontSize="12" Width="28" Height="28"
                                Background="Transparent" Foreground="White" BorderThickness="0"
                                Cursor="Hand" Click="BackButton_Click" ToolTip="后退"/>
                        <Button x:Name="ForwardButton" Content="▶" FontSize="12" Width="28" Height="28"
                                Background="Transparent" Foreground="White" BorderThickness="0"
                                Cursor="Hand" Click="ForwardButton_Click" ToolTip="前进"/>
                        <Button x:Name="RefreshButton" Content="↻" FontSize="14" Width="28" Height="28"
                                Background="Transparent" Foreground="White" BorderThickness="0"
                                Cursor="Hand" Click="RefreshButton_Click" ToolTip="刷新"/>
                    </StackPanel>
                    <TextBlock x:Name="TitleText" Text="轻燕 - 工作组" FontSize="14" FontWeight="SemiBold"
                               Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="MinimizeButton" Content="−" FontSize="16" Width="32" Height="28"
                                Background="Transparent" Foreground="White" BorderThickness="0"
                                Click="MinimizeButton_Click"/>
                        <Button x:Name="CloseButton" Content="✕" FontSize="12" Width="32" Height="28"
                                Background="Transparent" Foreground="White" BorderThickness="0"
                                Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <wv2:WebView2 Grid.Row="1" x:Name="WorkGroupWebView"/>
        </Grid>
    </Border>
</Window>