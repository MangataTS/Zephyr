<Window x:Class="ZephyrDesktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="轻燕桌面端" Height="480" Width="380"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Border CornerRadius="12" Background="White" Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.12" Color="#000000"/>
        </Border.Effect>
        <Grid Margin="32,40,32,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="轻燕桌面端" FontSize="28" FontWeight="SemiBold"
                       Foreground="#1f2937" HorizontalAlignment="Center"/>
            <TextBlock Grid.Row="2" Text="登录以开始使用" FontSize="14"
                       Foreground="#6b7280" HorizontalAlignment="Center"/>

            <Border Grid.Row="4" CornerRadius="8" BorderBrush="#d1d5db" BorderThickness="1" Background="#f9fafb">
                <TextBox x:Name="UsernameBox"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Height="44" FontSize="14" Padding="12,0"
                         BorderThickness="0" Background="Transparent"
                         VerticalContentAlignment="Center"/>
            </Border>

            <Border Grid.Row="6" CornerRadius="8" BorderBrush="#d1d5db" BorderThickness="1" Background="#f9fafb">
                <PasswordBox x:Name="PasswordBox"
                             Height="44" FontSize="14" Padding="12,0"
                             BorderThickness="0" Background="Transparent"
                             VerticalContentAlignment="Center"
                             PasswordChanged="PasswordBox_PasswordChanged"/>
            </Border>

            <TextBlock Grid.Row="8" Text="{Binding ErrorMessage}"
                       Foreground="#ef4444" FontSize="12" TextWrapping="Wrap"
                       Margin="0,4,0,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasError}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <Grid Grid.Row="11">
                <Button x:Name="LoginButton"
                        Command="{Binding LoginCommand}"
                        Height="44" FontSize="15" FontWeight="SemiBold"
                        Foreground="White" Content="登 录"
                        Cursor="Hand" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="BtnBorder" CornerRadius="8" Background="#3B82F6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BtnBorder" Property="Background" Value="#2563eb"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="BtnBorder" Property="Background" Value="#1d4ed8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
